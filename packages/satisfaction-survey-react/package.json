{
  "name": "satisfaction-survey-react",
  "version": "0.1.0",
  "description": "Popup de avaliação (nota 1–5 + comentário) disparado por IntersectionObserver — plugável em qualquer app React",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "~5.6.2"
  },
  "keywords": [
    "react",
    "survey",
    "satisfaction",
    "intersection-observer",
    "popup"
  ],
  "license": "MIT"
}
